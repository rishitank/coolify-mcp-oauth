# Public base URL this service is reachable at (no trailing slash).
# This doubles as the OAuth issuer and the MCP resource URL is derived
# from it as `${PUBLIC_URL}/mcp`.
PUBLIC_URL=https://coolify-mcp-oauth.example.com

PORT=3000

# Google OAuth 2.0 Client (Google Cloud Console > APIs & Services >
# Credentials > Create Credentials > OAuth client ID > Web application).
# Authorized redirect URI must be: ${PUBLIC_URL}/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 32 random bytes, base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Encrypts each user's Coolify API token at rest. Losing this key makes all
# stored Coolify credentials unrecoverable (users would need to re-enter them).
CREDENTIAL_ENCRYPTION_KEY=

# 32+ random bytes, base64 (same generation command as above). Signs the
# login-session cookie and oidc-provider's own interaction/session cookies.
COOKIE_SECRET=

# Where the SQLite database and generated JWKS signing keys are persisted.
# Must be a durable volume in production — losing it invalidates all
# sessions and orphans stored (encrypted) Coolify credentials.
DATA_DIR=./data

# Optional: comma-separated allowlist. If set, only these Google accounts
# may log in — recommended for a personal/private deployment. Leave unset
# to allow any Google account (appropriate for a shared public deployment,
# since each user's Coolify credentials stay isolated to their own account).
ALLOWED_GOOGLE_EMAILS=

# How to launch the Coolify MCP server per session. Leave unset when
# running outside Docker (defaults to `npx -y @masonator/coolify-mcp@latest`,
# fetching the package on demand). The Dockerfile in this repo sets these
# to invoke a pinned, globally pre-installed binary instead — faster
# per-session startup, no runtime dependency on npm's registry.
COOLIFY_MCP_COMMAND=
COOLIFY_MCP_ARGS=

NODE_ENV=production
